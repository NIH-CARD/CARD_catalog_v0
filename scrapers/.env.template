# API Keys and Tokens for CARD Catalog Scrapers
# Copy this file to .env and fill in your actual values
# DO NOT commit the .env file to version control

# GitHub Personal Access Token
# Get one at: https://github.com/settings/tokens
# Needs: public_repo scope
GITHUB_TOKEN=your_github_token_here

# Anthropic API Key
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# API KEY To access NCBI Entrez Utilities with higher rate limits
# Instruction to get one at: https://support.nlm.nih.gov/kbArticle/?pn=KA-05317
NCBI_API_KEY=your_ncbi_api_key_here
