curl -LsSf https://astral.sh/uv/install.sh | sh
export PATH=""$HOME/.local/bin:$PATH""

# Clone and install
git clone https://github.com/xuiltul/animaworks.git && cd animaworks
uv sync                 # downloads Python 3.12+ and all dependencies

# Start
